{
  "models": {
    "chat-model": {
      "display_name": "Chat model",
      "provider": "openai-compatible",
      "api_style": "chat",
      "model_id": "replace-with-model-id",
      "api_key_env": "LAB_API_KEY",
      "base_url_env": "LAB_BASE_URL",
      "reasoning": "max",
      "send_reasoning_effort": true,
      "stream": true,
      "leaderboard_preset": true,
      "require_usage": true,
      "response_model_ids": ["replace-with-provider-returned-model-id"],
      "chat_output_token_field": "max_completion_tokens",
      "max_tokens": 128000,
      "ctx": 1000000
    }
  }
}
